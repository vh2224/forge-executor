{
  "name": "@opengsd/mcp-server",
  "version": "2.0.1",
  "description": "MCP server exposing GSD orchestration tools for compatible clients",
  "license": "MIT",
  "gsd": {
    "linkable": true,
    "scope": "@opengsd",
    "name": "mcp-server"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-gsd/gsd-pi.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./readers/graph": {
      "types": "./dist/readers/graph.d.ts",
      "import": "./dist/readers/graph.js"
    },
    "./readers/paths": {
      "types": "./dist/readers/paths.d.ts",
      "import": "./dist/readers/paths.js"
    },
    "./readers/roadmap": {
      "types": "./dist/readers/roadmap.d.ts",
      "import": "./dist/readers/roadmap.js"
    },
    "./readers/state": {
      "types": "./dist/readers/state.d.ts",
      "import": "./dist/readers/state.js"
    }
  },
  "bin": {
    "gsd-mcp-server": "./bin/gsd-mcp-server.js"
  },
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.cjs && tsc --incremental false",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "pnpm run build:test && node --test dist/mcp-server.test.js dist/remote-questions.test.js dist/moonshot-tool-schema.test.js dist/pid-registry.test.js dist/probe-mode.test.js dist/stdio-watchdog.test.js dist/cli-runner.test.js dist/readers/graph.test.js dist/readers/paths.test.js dist/readers/readers.test.js"
  },
  "dependencies": {
    "@gsd/pi-ai": "workspace:*",
    "@opengsd/contracts": "workspace:*",
    "@opengsd/rpc-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "bin",
    "dist",
    "!dist/**/*.test.*"
  ]
}
