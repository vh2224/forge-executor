{
  "name": "@gsd/pi-agent-core",
  "version": "2.0.2",
  "description": "General-purpose agent with transport abstraction, state management, and attachment support",
  "type": "module",
  "gsd": {
    "linkable": true,
    "scope": "@gsd",
    "name": "pi-agent-core"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.cjs",
    "build": "node ../../scripts/clean-package-dist.cjs && tsc -p tsconfig.json --incremental false",
    "test": "vitest --run",
    "test:harness": "vitest --run --config vitest.harness.config.ts",
    "coverage:harness": "vitest --run --config vitest.harness.config.ts --coverage",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.5",
    "ignore": "7.0.5",
    "typebox": "1.1.38",
    "yaml": "2.9.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "transport",
    "state-management"
  ],
  "author": "Mario Zechner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/earendil-works/pi-mono.git",
    "directory": "packages/agent"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
