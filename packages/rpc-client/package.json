{
  "name": "@opengsd/rpc-client",
  "version": "2.0.1",
  "description": "Standalone RPC client SDK for GSD — zero internal dependencies",
  "license": "MIT",
  "gsd": {
    "linkable": true,
    "scope": "@opengsd",
    "name": "rpc-client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-gsd/gsd-pi.git",
    "directory": "packages/rpc-client"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.cjs && tsc -p tsconfig.json --incremental false",
    "test": "node --test dist/rpc-client.test.js"
  },
  "dependencies": {
    "@opengsd/contracts": "workspace:*"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
